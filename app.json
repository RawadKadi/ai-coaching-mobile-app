{
  "expo": {
    "name": "bolt-expo-nativewind",
    "slug": "bolt-expo-nativewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coachingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coaching.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Allow $(PRODUCT_NAME) to read your steps to sync them with your coach.",
        "NSHealthUpdateUsageDescription": "Allow $(PRODUCT_NAME) to sync your steps with your coach.",
        "NSMotionUsageDescription": "Allow $(PRODUCT_NAME) to read your steps to sync them with your coach."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.coaching.app",
      "permissions": [
        "android.permission.health.READ_STEPS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "coachingapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "react-native-health-connect"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
